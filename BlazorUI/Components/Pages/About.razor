@page "/acerca-de"
@using AppsielPrintManager.Core.Interfaces
@using Microsoft.Maui.ApplicationModel
@implements IDisposable
@inject IPlatformService PlatformService
@inject NavigationManager NavigationManager

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0">Ayuda y Soporte</h2>
            <p class="text-secondary mb-0">Información del sistema y canales de atención</p>
        </div>
        <div class="d-flex align-items-center bg-white rounded-pill px-3 py-2 shadow-sm border" style="border-color: var(--card-stroke) !important">
            <div class="status-dot @(IsServiceRunning ? "active" : "")"></div>
            <span class="ms-2 fw-bold small @(IsServiceRunning ? "text-success" : "text-danger")">
                @(IsServiceRunning ? "SERVICIO ACTIVO" : "SERVICIO INACTIVO")
            </span>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">
            <div class="card border-0 shadow-sm p-5 text-center about-card">
                <!-- Logo Container -->
                <div class="logo-container mb-4 mx-auto">
                    <img src="images/logo_compress.png" alt="Appsiel Print Manager" class="img-fluid" style="max-height: 80px; object-fit: contain;" />
                </div>

                <h3 class="fw-bold mb-2">Appsiel Print Manager</h3>
                
                <div class="version-badge mb-4">
                    <span class="badge rounded-pill bg-light text-primary px-3 py-2 border">
                        Versión @AppVersion
                    </span>
                </div>

                <p class="text-muted mb-5 px-md-4">
                    Este gestor de impresión garantiza el flujo continuo, rápido y estable de sus facturas, comandas y tickets directamente desde la nube hacia el hardware local de su punto de venta.
                </p>

                <!-- Action Buttons -->
                <div class="d-grid gap-3 d-sm-flex justify-content-sm-center">
                    <button class="btn btn-primary btn-lg px-4 fw-bold d-flex align-items-center justify-content-center" @onclick="OpenWebsite">
                        <svg class="me-2" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
                        Visitar Sitio Web
                    </button>
                    <button class="btn btn-outline-secondary btn-lg px-4 fw-bold d-flex align-items-center justify-content-center" @onclick="WhatsAppSupport">
                        <svg class="me-2" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
                        Contactar Soporte
                    </button>
                </div>

                <hr class="my-5 opacity-10" />

                <p class="small text-muted mb-0">
                    &copy; @DateTime.Now.Year Appsiel. Todos los derechos reservados.
                </p>
            </div>
        </div>
    </div>
</div>



@code {
    private string AppVersion { get; set; } = "1.0.0";
    private bool IsServiceRunning { get; set; }
    private bool _isDisposed;
    private PeriodicTimer? _timer;

    protected override void OnInitialized()
    {
        AppVersion = VersionTracking.CurrentVersion;
        UpdateServiceStatus();
        _ = StartMonitoringAsync();
    }

    private void UpdateServiceStatus()
    {
        IsServiceRunning = PlatformService.IsBackgroundServiceRunning;
    }

    private async Task StartMonitoringAsync()
    {
        _timer = new PeriodicTimer(TimeSpan.FromSeconds(1));
        try
        {
            while (await _timer.WaitForNextTickAsync() && !_isDisposed)
            {
                UpdateServiceStatus();
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { }
    }

    private async Task OpenWebsite()
    {
        try
        {
            await Browser.Default.OpenAsync(new Uri("https://appsiel.com.co/"), BrowserLaunchMode.SystemPreferred);
        }
        catch { }
    }

    private async Task WhatsAppSupport()
    {
        try
        {
            await Browser.Default.OpenAsync(new Uri("https://api.whatsapp.com/send/?phone=%2B573014159571&text&type=phone_number&app_absent=0"), BrowserLaunchMode.SystemPreferred);
        }
        catch { }
    }

    public void Dispose()
    {
        _isDisposed = true;
        _timer?.Dispose();
    }
}
