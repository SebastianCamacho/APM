@page "/basculas"
@using AppsielPrintManager.Core.Interfaces
@using AppsielPrintManager.Core.Models
@using AppsielPrintManager.Core.Enums
@using System.Text.Json
@implements IDisposable
@inject IScaleRepository ScaleRepository
@inject IPlatformService PlatformService
@inject ILoggingService Logger
@inject NavigationManager NavigationManager

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0">Básculas</h2>
            <p class="text-secondary mb-0">Administra y configura las balanzas del sistema</p>
        </div>
        <div class="d-flex align-items-center bg-card-dark rounded-pill px-3 py-2 shadow-sm border">
            <div class="status-dot @(IsServiceRunning ? "active" : "")"></div>
            <span class="ms-2 fw-bold small @(IsServiceRunning ? "text-success" : "text-danger")">
                @(IsServiceRunning ? "SERVICIO ACTIVO" : "SERVICIO INACTIVO")
            </span>
        </div>
    </div>

    <!-- Actions -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fs-4 fw-bold mb-0">Mis Balanzas</h3>
        <button class="btn btn-primary px-4 fw-bold d-flex align-items-center" @onclick="NavigateToAddScale">
            <svg class="me-2" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
            Nueva Báscula
        </button>
    </div>

    @if (IsLoading)
    {
        <div class="d-flex justify-content-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
        </div>
    }
    else if (ScaleList == null || !ScaleList.Any())
    {
        <div class="empty-state card border-0 shadow-sm py-5">
            <div class="empty-state-icon">
                <svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.24 12.24a6 6 0 0 0-8.49-8.49L5 10.5V19h8.5z"></path><line x1="16" y1="8" x2="2" y2="22"></line><line x1="17.5" y1="15" x2="9" y2="15"></line></svg>
            </div>
            <h4 class="fw-bold text-secondary">No hay básculas configuradas aún.</h4>
            <p class="text-muted">Haz clic en el botón "Nueva Báscula" para comenzar.</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in ScaleList)
            {
                <div class="col-12 col-lg-6">
                    <div class="card scale-card h-100 shadow-sm p-4 border-0" @onclick="() => NavigateToEditScale(item.Scale.Id)">
                        <div class="d-flex gap-3 align-items-start">
                            <!-- Icon Box with Status Aura -->
                            <div class="position-relative">
                                <div class="icon-box">
                                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v18"/><path d="m19 8 3 8a5 5 0 0 1-6 0zV7"/><path d="M3 7h1a17 17 0 0 0 8-2 17 17 0 0 0 8 2h1"/><path d="m5 8 3 8a5 5 0 0 1-6 0zV7"/><path d="M7 21h10"/></svg>
                                </div>
                                <div class="status-indicator-dot @GetStatusClass(item.Status)" title="@item.Status"></div>
                            </div>

                            <!-- Content -->
                            <div class="flex-grow-1">
                                <div class="d-flex flex-wrap align-items-center gap-2 mb-1">
                                    <h5 class="fw-bold mb-0">@item.Scale.Name</h5>
                                    <span class="port-badge">@item.Scale.PortName</span>
                                </div>
                                <div class="text-muted small mb-2">ID: @item.Scale.Id</div>
                                
                                <div class="scale-info-text">
                                    @item.Scale.BaudRate bps • @item.Scale.DataBits bits • @item.Scale.Parity
                                </div>

                                <div class="scale-status-text" style="color: @GetStatusColor(item.Status)">
                                    @TranslateStatus(item.Status)
                                </div>

                                @if (!string.IsNullOrEmpty(item.ErrorMessage))
                                {
                                    <div class="text-danger small mt-1 italic">
                                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-1"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
                                        @item.ErrorMessage
                                    </div>
                                }
                            </div>

                            <!-- Action Buttons -->
                            <div class="action-buttons d-flex gap-2" @onclick:stopPropagation="true">
                                <button class="btn-action btn-edit" title="Editar" @onclick="() => NavigateToEditScale(item.Scale.Id)">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                                </button>
                                <button class="btn-action btn-delete" title="Eliminar" @onclick="() => DeleteScale(item)">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<ScaleViewModelItem> ScaleList { get; set; } = new();
    private bool IsLoading { get; set; } = true;
    private bool IsServiceRunning { get; set; }
    private bool IsBusy { get; set; }
    
    private bool _isDisposed;
    private PeriodicTimer? _timer;
    private readonly HttpClient _httpClient = new() { Timeout = TimeSpan.FromSeconds(1) };

    protected override async Task OnInitializedAsync()
    {
        // Guard: Básculas no está disponible en Android
        if (DeviceInfo.Platform == DevicePlatform.Android)
        {
            NavigationManager.NavigateTo("/");
            return;
        }

        UpdateServiceStatus();
        await LoadScales();
        _ = StartMonitoringAsync();
    }

    private void UpdateServiceStatus()
    {
        IsServiceRunning = PlatformService.IsBackgroundServiceRunning;
    }

    private async Task LoadScales()
    {
        IsLoading = true;
        try
        {
            var loaded = await ScaleRepository.GetAllAsync();
            var sorted = loaded.OrderBy(s => s.Id).ToList();
            
            // Sync current items
            ScaleList = sorted.Select(s => new ScaleViewModelItem(s)).ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError($"Error loading scales: {ex.Message}", ex, "ScalesPage");
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task StartMonitoringAsync()
    {
        _timer = new PeriodicTimer(TimeSpan.FromSeconds(1));
        try
        {
            while (await _timer.WaitForNextTickAsync() && !_isDisposed)
            {
                UpdateServiceStatus();
                await UpdateScaleStatuses();
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { }
    }

    private async Task UpdateScaleStatuses()
    {
        try
        {
            // Polling to WorkerService for real-time status
            var json = await _httpClient.GetStringAsync("http://localhost:7000/websocket/status");
            var statusData = JsonSerializer.Deserialize<WorkerStatusDto>(json, new JsonSerializerOptions { PropertyNameCaseInsensitive = true });

            if (statusData?.ScaleStatuses != null)
            {
                foreach (var statusInfo in statusData.ScaleStatuses)
                {
                    var item = ScaleList.FirstOrDefault(s => s.Scale.Id == statusInfo.ScaleId);
                    if (item != null)
                    {
                        item.Status = statusInfo.Status;
                        item.ErrorMessage = statusInfo.ErrorMessage;
                    }
                }
            }
        }
        catch { /* Service might be down */ }
    }

    private void NavigateToAddScale()
    {
        NavigationManager.NavigateTo("/scale-detail");
    }

    private void NavigateToEditScale(string id)
    {
        NavigationManager.NavigateTo($"/scale-detail/{id}");
    }

    private async Task DeleteScale(ScaleViewModelItem item)
    {
        if (IsBusy) return;
        IsBusy = true;
        try
        {
            await ScaleRepository.DeleteAsync(item.Scale.Id);
            ScaleList.Remove(item);
            
            // Notify background service
            try { await _httpClient.GetAsync("http://localhost:7000/websocket/reload-scales"); } catch { }
            
            Logger.LogInfo($"Scale '{item.Scale.Id}' deleted.", "ScalesPage");
        }
        catch (Exception ex)
        {
            Logger.LogError($"Error deleting scale: {ex.Message}", ex, "ScalesPage");
        }
        finally
        {
            IsBusy = false;
        }
    }

    private string GetStatusClass(ScaleStatus status) => status switch
    {
        ScaleStatus.Connected => "status-connected",
        ScaleStatus.Error => "status-error",
        _ => "status-disconnected"
    };

    private string GetStatusColor(ScaleStatus status) => status switch
    {
        ScaleStatus.Connected => "var(--success)",
        ScaleStatus.Error => "var(--danger-icon)",
        _ => "var(--text-muted)"
    };

    private string TranslateStatus(ScaleStatus status) => status switch
    {
        ScaleStatus.Connected => "Conectada",
        ScaleStatus.Disconnected => "Desconectada",
        ScaleStatus.Error => "Error de Conexión",
        _ => "Desconocido"
    };

    public void Dispose()
    {
        _isDisposed = true;
        _timer?.Dispose();
        _httpClient.Dispose();
    }

    // ViewModel Item class
    private class ScaleViewModelItem
    {
        public Scale Scale { get; }
        public ScaleStatus Status { get; set; } = ScaleStatus.Disconnected;
        public string? ErrorMessage { get; set; }

        public ScaleViewModelItem(Scale scale) => Scale = scale;
    }

    private class WorkerStatusDto
    {
        public List<ScaleStatusInfo> ScaleStatuses { get; set; } = new();
    }
}
