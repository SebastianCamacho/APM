@page "/logs"
@using AppsielPrintManager.Core.Interfaces
@using AppsielPrintManager.Core.Enums
@implements IDisposable
@inject ILoggingService LoggingService
@inject IJSRuntime JS

<div class="container-fluid py-4 px-3 px-md-4">
    <!-- Header -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4 gap-3">
        <div class="ps-1">
            <h2 class="fw-bold mb-0">Registros del Sistema</h2>
            <p class="text-secondary mb-0">Monitorea la actividad y errores en tiempo real</p>
        </div>
        <div class="d-flex gap-2 w-100 w-md-auto">
            <button class="btn btn-outline-danger flex-grow-1 flex-md-grow-0 px-4 fw-bold d-flex align-items-center justify-content-center" @onclick="ClearLogs">
                <svg class="me-2" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
                <span class="d-none d-sm-inline">Limpiar Todo</span>
                <span class="d-inline d-sm-none">Limpiar</span>
            </button>
            <button class="btn btn-primary flex-grow-1 flex-md-grow-0 px-4 fw-bold d-flex align-items-center justify-content-center" @onclick="RefreshLogs">
                <svg class="me-2 @(IsLoading ? "spinner" : "")" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"></polyline><polyline points="1 20 1 14 7 14"></polyline><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l5.64 5.64A9 9 0 0 0 20.49 15"></path></svg>
                Refrescar
            </button>
        </div>
    </div>

    <!-- Filters Bar -->
    <div class="card border-0 shadow-sm p-3 mb-4 filter-bar">
        <div class="row g-3 align-items-end">
            <div class="col-12 col-md-3">
                <label class="form-label small fw-bold text-secondary">Buscar</label>
                <div class="input-group">
                    <span class="input-group-text bg-card-dark border-end-0">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                    </span>
                    <input type="text" class="form-control border-start-0 ps-0" placeholder="Mensaje, servicio..." @bind="SearchText" @bind:event="oninput" />
                </div>
            </div>
            <div class="col-6 col-md-2">
                <label class="form-label small fw-bold text-secondary">Nivel</label>
                <select class="form-select" @bind="SelectedLevel">
                    @foreach (var level in AvailableLevels)
                    {
                        <option value="@level">@level</option>
                    }
                </select>
            </div>
            <div class="col-6 col-md-2">
                <label class="form-label small fw-bold text-secondary">Límite</label>
                <select class="form-select" @bind="LogLimit">
                    <option value="50">50</option>
                    <option value="100">100</option>
                    <option value="250">250</option>
                    <option value="500">500</option>
                </select>
            </div>
            <div class="col-6 col-md-2">
                <label class="form-label small fw-bold text-secondary">Desde</label>
                <input type="date" class="form-control" @bind="StartDate" />
            </div>
            <div class="col-6 col-md-2">
                <label class="form-label small fw-bold text-secondary">Hasta</label>
                <input type="date" class="form-control" @bind="EndDate" />
            </div>
            <div class="col-12 col-md-1 d-flex align-items-center justify-content-md-center pb-1">
                <div class="form-check form-switch cursor-pointer">
                    <input class="form-check-input" type="checkbox" role="switch" id="autoRefresh" @bind="IsAutoRefreshEnabled">
                    <label class="form-check-label small fw-bold text-secondary" for="autoRefresh">Auto</label>
                </div>
            </div>
        </div>
    </div>

    <!-- Logs Table -->
    <div class="card border-0 shadow-sm overflow-hidden log-table-card">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th class="ps-4">TIMESTAMP</th>
                        <th>NIVEL</th>
                        <th>SERVICIO</th>
                        <th class="pe-4 text-nowrap">MENSAJE</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!LogEntries.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5 text-muted italic">
                                No se encontraron registros con los filtros actuales.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var log in LogEntries)
                        {
                            <tr>
                                <td class="ps-4 text-secondary small align-middle text-nowrap">@log.Timestamp.ToString("yyyy-MM-dd HH:mm:ss.fff")</td>
                                <td class="align-middle">
                                    <span class="log-badge @GetBadgeClass(log.Level)">
                                        @log.Level.ToString().ToUpper()
                                    </span>
                                </td>
                                <td class="text-secondary small align-middle">@log.Service</td>
                                <td class="pe-4 align-middle @GetMessageClass(log.Level)">
                                    <div class="text-break" style="min-width: 250px;">@log.Message</div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>



@code {
    private List<LogMessage> LogEntries { get; set; } = new();
    private bool IsLoading { get; set; }
    private bool IsAutoRefreshEnabled { get; set; } = true;
    
    private string _searchText = string.Empty;
    public string SearchText 
    { 
        get => _searchText; 
        set { _searchText = value; _ = LoadLogs(); } 
    }

    private string _selectedLevel = "Todos";
    public string SelectedLevel
    {
        get => _selectedLevel;
        set { _selectedLevel = value; _ = LoadLogs(); }
    }

    private int _logLimit = 100;
    public int LogLimit
    {
        get => _logLimit;
        set { _logLimit = value; _ = LoadLogs(); }
    }

    private DateTime _startDate = DateTime.Today.AddDays(-7);
    public DateTime StartDate
    {
        get => _startDate;
        set { _startDate = value; _ = LoadLogs(); }
    }

    private DateTime _endDate = DateTime.Today.AddDays(1).AddTicks(-1);
    public DateTime EndDate
    {
        get => _endDate;
        set { _endDate = value; _ = LoadLogs(); }
    }

    public string[] AvailableLevels { get; } = new[] { "Todos", "Info", "Warning", "Error", "Debug" };

    private bool _isDisposed;
    private PeriodicTimer? _timer;

    protected override async Task OnInitializedAsync()
    {
        await LoadLogs();
        _ = StartMonitoringAsync();
    }

    private async Task StartMonitoringAsync()
    {
        _timer = new PeriodicTimer(TimeSpan.FromSeconds(2));
        try
        {
            while (await _timer.WaitForNextTickAsync() && !_isDisposed)
            {
                if (IsAutoRefreshEnabled && !IsLoading)
                {
                    await LoadLogs();
                    await InvokeAsync(StateHasChanged);
                }
            }
        }
        catch (OperationCanceledException) { }
    }

    private async Task LoadLogs()
    {
        IsLoading = true;
        try
        {
            var rawLogs = await Task.Run(() => LoggingService.GetLogs());
            
            var filtered = rawLogs
                .Where(l => l.Timestamp >= StartDate && l.Timestamp <= EndDate);

            if (SelectedLevel != "Todos" && Enum.TryParse<AppsielPrintManager.Core.Interfaces.LogLevel>(SelectedLevel, out var levelEnum))
            {
                filtered = filtered.Where(l => l.Level == levelEnum);
            }

            if (!string.IsNullOrWhiteSpace(SearchText))
            {
                var lowerSearch = SearchText.ToLowerInvariant();
                filtered = filtered.Where(l =>
                    l.Message.ToLowerInvariant().Contains(lowerSearch) ||
                    l.Service.ToLowerInvariant().Contains(lowerSearch));
            }

            LogEntries = filtered.OrderByDescending(l => l.Timestamp).Take(LogLimit).ToList();
        }
        catch { }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task RefreshLogs()
    {
        await LoadLogs();
    }

    private async Task ClearLogs()
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", "Estás a punto de eliminar todos los registros. ¿Deseas continuar?");
        if (confirmed)
        {
            LoggingService.ClearLogs();
            await LoadLogs();
        }
    }

    private string GetBadgeClass(AppsielPrintManager.Core.Interfaces.LogLevel level) => level switch
    {
        AppsielPrintManager.Core.Interfaces.LogLevel.Info => "bg-info-tint",
        AppsielPrintManager.Core.Interfaces.LogLevel.Warning => "bg-warning-tint",
        AppsielPrintManager.Core.Interfaces.LogLevel.Error => "bg-danger-tint",
        AppsielPrintManager.Core.Interfaces.LogLevel.Debug => "bg-debug-tint",
        _ => "bg-light"
    };

    private string GetMessageClass(AppsielPrintManager.Core.Interfaces.LogLevel level) => level switch
    {
        AppsielPrintManager.Core.Interfaces.LogLevel.Error => "text-error fw-bold",
        AppsielPrintManager.Core.Interfaces.LogLevel.Warning => "text-warning",
        _ => ""
    };

    public void Dispose()
    {
        _isDisposed = true;
        _timer?.Dispose();
    }
}
