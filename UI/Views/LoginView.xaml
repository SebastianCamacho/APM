<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:UI.ViewModels"
             x:Class="UI.Views.LoginView"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             Title="Login">

    <VerticalStackLayout
        Padding="30"
        Spacing="25"
        VerticalOptions="Center"
        HorizontalOptions="Center">

        <Label Text="Iniciar Sesión"
               FontSize="32"
               FontAttributes="Bold"
               HorizontalOptions="Center" />

        <Grid WidthRequest="250" ColumnDefinitions="*, Auto" HorizontalOptions="Center">
            <Entry Grid.Column="0"
                   Placeholder="Contraseña"
                   IsPassword="{Binding IsPasswordHidden}"
                   Text="{Binding Password}" />
            <Button Grid.Column="1"
                    Command="{Binding TogglePasswordVisibilityCommand}"
                    BackgroundColor="Transparent"
                    TextColor="{AppThemeBinding Light=Black, Dark=White}"
                    FontSize="18"
                    Padding="10,0"
                    VerticalOptions="Center">
                <Button.Triggers>
                    <DataTrigger TargetType="Button" Binding="{Binding IsPasswordHidden}" Value="True">
                        <Setter Property="Text" Value="👁" />
                    </DataTrigger>
                    <DataTrigger TargetType="Button" Binding="{Binding IsPasswordHidden}" Value="False">
                        <Setter Property="Text" Value="🙈" />
                    </DataTrigger>
                </Button.Triggers>
            </Button>
        </Grid>

        <Button Text="Entrar"
                WidthRequest="250"
                Command="{Binding LoginCommand}" />

        <Label Text="{Binding ErrorMessage}"
               TextColor="Red"
               HorizontalOptions="Center"
               IsVisible="{Binding HasError}" />
    </VerticalStackLayout>
</ContentPage>