<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:UI.ViewModels"
             x:Class="UI.Views.LoginView"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             Title="Login">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Style TargetType="Entry">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="TextColor" Value="{AppThemeBinding Light={DynamicResource Black}, Dark={DynamicResource White}}" />
                <Setter Property="BackgroundColor" Value="Transparent" />
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid>
        <!-- Contenido Central del Login -->
        <VerticalStackLayout
            Padding="30"
            Spacing="30"
            VerticalOptions="Center"
            HorizontalOptions="Center">

            <Image Source="app_icon.png" HeightRequest="100" HorizontalOptions="Center" Margin="0,0,0,10"/>

            <Label Text="Iniciar Sesión"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="{DynamicResource Primary}"
                   HorizontalOptions="Center" />

            <VerticalStackLayout Spacing="8" WidthRequest="280" HorizontalOptions="Center">
                <Label Text="Contraseña" FontSize="12" FontAttributes="Bold" TextColor="{DynamicResource Primary}" />
                <Border StrokeShape="RoundRectangle 8" StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={DynamicResource Gray600}}" HeightRequest="45">
                    <Grid ColumnDefinitions="*, Auto">
                        <Entry Grid.Column="0"
                               Placeholder="Ingresa la contraseña..."
                               IsPassword="{Binding IsPasswordHidden}"
                               Text="{Binding Password}"
                               VerticalOptions="Center"
                               Margin="10,0,0,0" />
                        <ImageButton Grid.Column="1"
                                     Command="{Binding TogglePasswordVisibilityCommand}"
                                     BackgroundColor="Transparent"
                                     WidthRequest="24"
                                     HeightRequest="24"
                                     Margin="10,0"
                                     VerticalOptions="Center">
                            <ImageButton.Triggers>
                                <DataTrigger TargetType="ImageButton" Binding="{Binding IsPasswordHidden}" Value="True">
                                    <Setter Property="Source" Value="icono_visible.png" />
                                </DataTrigger>
                                <DataTrigger TargetType="ImageButton" Binding="{Binding IsPasswordHidden}" Value="False">
                                    <Setter Property="Source" Value="icono_no_visible.png" />
                                </DataTrigger>
                            </ImageButton.Triggers>
                        </ImageButton>
                    </Grid>
                </Border>
            </VerticalStackLayout>

            <Button Text="Entrar"
                    WidthRequest="280"
                    HeightRequest="45"
                    FontSize="15"
                    CornerRadius="8"
                    Command="{Binding LoginCommand}" />

            <Label Text="{Binding ErrorMessage}"
                   TextColor="Red"
                   HorizontalOptions="Center"
                   IsVisible="{Binding HasError}" />
        </VerticalStackLayout>

        <!-- Botón para detener el servicio en la esquina inferior derecha (Solo visible en Android) -->
        <VerticalStackLayout VerticalOptions="End" HorizontalOptions="End" Margin="20"
                             IsVisible="{OnPlatform Android=True, Default=False}">
            <ImageButton Source="icono_stop.png"
                         Command="{Binding StopServiceCommand}"
                         WidthRequest="40"
                         HeightRequest="40"
                         BackgroundColor="Transparent"
                         ToolTipProperties.Text="Detener Servicio de Impresión" />
            <Label Text="Detener"
                   FontSize="10"
                   TextColor="Gray"
                   HorizontalOptions="Center" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>