<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:UI.ViewModels"
             x:DataType="viewmodels:HomeViewModel"
             x:Class="UI.Views.HomePage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="White">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Style TargetType="Button" x:Key="HoverButtonStyle">
                <Setter Property="VisualStateManager.VisualStateGroups">
                    <VisualStateGroupList>
                        <VisualStateGroup x:Name="CommonStates">
                            <VisualState x:Name="Normal" />
                            <VisualState x:Name="PointerOver">
                                <VisualState.Setters>
                                    <Setter Property="Opacity" Value="0.85" />
                                    <!-- Escalado leve -->
                                    <Setter Property="Scale" Value="1.02" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="Disabled">
                                <VisualState.Setters>
                                    <Setter Property="Opacity" Value="0.6" />
                                    <Setter Property="Scale" Value="1" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateGroupList>
                </Setter>
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView BackgroundColor="{AppThemeBinding Light={StaticResource PageBgLight}, Dark={StaticResource PageBgDark}}">
        <VerticalStackLayout Spacing="0">
            <!-- Header Toolbar Falso -->
            <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource CardBgLight}, Dark={StaticResource CardBgDark}}" Padding="20,15" Margin="0,0,0,30">
                <Border.Shadow>
                    <Shadow Brush="#000000" Offset="0,2" Radius="5" Opacity="0.05" />
                </Border.Shadow>
                <Grid ColumnDefinitions="*, Auto">
                    <Label Grid.Column="0" Text="Inicio" FontSize="14" TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" VerticalOptions="Center" />
                    <!-- Status Indicator with Pulses -->
                    <HorizontalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="Center">
                        <Grid WidthRequest="12" HeightRequest="12" VerticalOptions="Center">
                            <!-- Aura de Pálpito -->
                            <BoxView x:Name="StatusAura" WidthRequest="12" HeightRequest="12" CornerRadius="6" 
                                     BackgroundColor="{Binding IsServiceRunning, Converter={StaticResource BoolToColorConverter}, ConverterParameter='Running|Stopped'}" Scale="1" Opacity="0.6" />
                            <!-- Punto Principal -->
                            <BoxView x:Name="StatusDot" WidthRequest="8" HeightRequest="8" CornerRadius="4" 
                                     BackgroundColor="{Binding IsServiceRunning, Converter={StaticResource BoolToColorConverter}, ConverterParameter='Running|Stopped'}" VerticalOptions="Center" HorizontalOptions="Center" />
                        </Grid>
                        <Label Text="{Binding ServiceStatusTitle}" FontSize="13" TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" FontAttributes="Bold" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Grid>
            </Border>

            <VerticalStackLayout Padding="30,0" Spacing="30">
                <!-- Welcome Title -->
                <VerticalStackLayout Spacing="5">
                    <Label Text="Bienvenido a Appsiel Print Manager" FontSize="26" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />
                    <Label Text="Panel de control principal del servicio de impresión." FontSize="14" TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" />
                </VerticalStackLayout>

                <!-- Layout para Escritorio (Windows/Mac) Lado a Lado -->
                <Grid ColumnDefinitions="*, *" ColumnSpacing="20" IsVisible="{OnPlatform WinUI=True, MacCatalyst=True, Default=False}">
                    <!-- Tarjeta 1: Estado del Servicio -->
                    <Border Grid.Column="0" StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="{AppThemeBinding Light={StaticResource CardStrokeLight}, Dark={StaticResource CardStrokeDark}}" BackgroundColor="{AppThemeBinding Light={StaticResource CardBgLight}, Dark={StaticResource CardBgDark}}" Padding="25">
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,4" Radius="8" Opacity="0.03" />
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="30">
                            <!-- Titulo de Tarjeta -->
                            <Grid ColumnDefinitions="*, Auto">
                                <Label Grid.Column="0" Text="Estado del Servicio" FontSize="16" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" VerticalOptions="Center" />
                                
                                <Border Grid.Column="1" StrokeShape="RoundRectangle 15" StrokeThickness="0" BackgroundColor="{Binding IsServiceRunning, Converter={StaticResource BoolToColorConverter}, ConverterParameter='RunningBg|StoppedBg'}" Padding="12,6">
                                    <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                        <Ellipse Fill="{Binding IsServiceRunning, Converter={StaticResource BoolToColorConverter}, ConverterParameter='Running|Stopped'}" WidthRequest="8" HeightRequest="8" VerticalOptions="Center" />
                                        <Label Text="{Binding ServiceStatus}" FontSize="12" FontAttributes="Bold" TextColor="{Binding IsServiceRunning, Converter={StaticResource BoolToColorConverter}, ConverterParameter='RunningText|StoppedText'}" VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                </Border>
                            </Grid>

                            <!-- Botones -->
                            <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                                <!-- Botón Iniciar -->
                                <Button Grid.Column="0" 
                                        Text="Iniciar" 
                                        ImageSource="icono_start.png"
                                        ContentLayout="Left, 8"
                                        Command="{Binding StartForegroundServiceCommand}"
                                        Style="{StaticResource HoverButtonStyle}"
                                        BackgroundColor="{Binding IsServiceRunning, Converter={StaticResource BoolToColorConverter}, ConverterParameter='DisabledBg|StartBg'}"
                                        TextColor="{Binding IsServiceRunning, Converter={StaticResource BoolToColorConverter}, ConverterParameter='DisabledText|White'}"
                                        FontAttributes="Bold"
                                        CornerRadius="8"
                                        HeightRequest="48"
                                        IsEnabled="{Binding IsServiceRunning, Converter={StaticResource InverseBoolConverter}}" />

                                <!-- Botón Detener -->
                                <Button Grid.Column="1" 
                                        Text="Detener" 
                                        ImageSource="icono_stop.png"
                                        ContentLayout="Left, 8"
                                        Command="{Binding StopForegroundServiceCommand}"
                                        Style="{StaticResource HoverButtonStyle}"
                                        BackgroundColor="{Binding IsServiceRunning, Converter={StaticResource BoolToColorConverter}, ConverterParameter='StopBg|DisabledBg'}"
                                        TextColor="{Binding IsServiceRunning, Converter={StaticResource BoolToColorConverter}, ConverterParameter='White|DisabledText'}"
                                        FontAttributes="Bold"
                                        CornerRadius="8"
                                        HeightRequest="48"
                                        IsEnabled="{Binding IsServiceRunning}" />
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Tarjeta 2: Conexiones WebSocket -->
                    <Border Grid.Column="1" StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="{AppThemeBinding Light={StaticResource CardStrokeLight}, Dark={StaticResource CardStrokeDark}}" BackgroundColor="{AppThemeBinding Light={StaticResource CardBgLight}, Dark={StaticResource CardBgDark}}" Padding="25">
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,4" Radius="8" Opacity="0.03" />
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="25">
                            <Label Text="Conexiones WebSocket" FontSize="16" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />

                            <!-- Info Box 1 -->
                            <Border StrokeShape="RoundRectangle 8" StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource InfoBoxBgLight}, Dark={StaticResource InfoBoxBgDark}}" Padding="20,15">
                                <Grid ColumnDefinitions="*, Auto">
                                    <Label Grid.Column="0" Text="Clientes conectados" FontSize="14" TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" VerticalOptions="Center" />
                                    <Label Grid.Column="1" Text="{Binding CurrentClientCount}" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource TextPurple}" VerticalOptions="Center" />
                                </Grid>
                            </Border>

                            <!-- Info Box 2 -->
                            <Border StrokeShape="RoundRectangle 8" StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource InfoBoxBgLight}, Dark={StaticResource InfoBoxBgDark}}" Padding="20,15">
                                <Grid ColumnDefinitions="*, Auto">
                                    <Label Grid.Column="0" Text="Estado del socket" FontSize="14" TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" VerticalOptions="Center" />
                                    <HorizontalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                                        <Ellipse Fill="{Binding IsWebSocketServerRunning, Converter={StaticResource BoolToColorConverter}, ConverterParameter='Running|Stopped'}" WidthRequest="6" HeightRequest="6" VerticalOptions="Center" />
                                        <Label Text="{Binding IsWebSocketServerRunning, Converter={StaticResource BoolToStringConverter}, ConverterParameter='Activo|Inactivo'}" FontSize="14" FontAttributes="Bold" TextColor="{Binding IsWebSocketServerRunning, Converter={StaticResource BoolToColorConverter}, ConverterParameter='RunningText|StoppedText'}" VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                </Grid>
                            </Border>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Layout para Móvil (Android/iOS) Apilados uno debajo de otro -->
                <VerticalStackLayout Spacing="20" IsVisible="{OnPlatform Android=True, iOS=True, Default=False}">
                    <!-- Tarjeta 1: Estado del Servicio -->
                    <Border StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="{AppThemeBinding Light={StaticResource CardStrokeLight}, Dark={StaticResource CardStrokeDark}}" BackgroundColor="{AppThemeBinding Light={StaticResource CardBgLight}, Dark={StaticResource CardBgDark}}" Padding="25">
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,4" Radius="8" Opacity="0.03" />
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="30">
                            <!-- Titulo de Tarjeta -->
                            <Grid ColumnDefinitions="*, Auto">
                                <Label Grid.Column="0" Text="Estado del Servicio" FontSize="16" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" VerticalOptions="Center" />
                                
                                <Border Grid.Column="1" StrokeShape="RoundRectangle 15" StrokeThickness="0" BackgroundColor="{Binding IsServiceRunning, Converter={StaticResource BoolToColorConverter}, ConverterParameter='RunningBg|StoppedBg'}" Padding="12,6">
                                    <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                        <Ellipse Fill="{Binding IsServiceRunning, Converter={StaticResource BoolToColorConverter}, ConverterParameter='Running|Stopped'}" WidthRequest="8" HeightRequest="8" VerticalOptions="Center" />
                                        <Label Text="{Binding ServiceStatus}" FontSize="12" FontAttributes="Bold" TextColor="{Binding IsServiceRunning, Converter={StaticResource BoolToColorConverter}, ConverterParameter='RunningText|StoppedText'}" VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                </Border>
                            </Grid>

                            <!-- Botones -->
                            <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                                <!-- Botón Iniciar -->
                                <Button Grid.Column="0" 
                                        Text="Iniciar" 
                                        ImageSource="icono_start.png"
                                        ContentLayout="Left, 8"
                                        Command="{Binding StartForegroundServiceCommand}"
                                        Style="{StaticResource HoverButtonStyle}"
                                        BackgroundColor="{Binding IsServiceRunning, Converter={StaticResource BoolToColorConverter}, ConverterParameter='DisabledBg|StartBg'}"
                                        TextColor="{Binding IsServiceRunning, Converter={StaticResource BoolToColorConverter}, ConverterParameter='DisabledText|White'}"
                                        FontAttributes="Bold"
                                        CornerRadius="8"
                                        HeightRequest="48"
                                        IsEnabled="{Binding IsServiceRunning, Converter={StaticResource InverseBoolConverter}}" />

                                <!-- Botón Detener -->
                                <Button Grid.Column="1" 
                                        Text="Detener" 
                                        ImageSource="icono_stop.png"
                                        ContentLayout="Left, 8"
                                        Command="{Binding StopForegroundServiceCommand}"
                                        Style="{StaticResource HoverButtonStyle}"
                                        BackgroundColor="{Binding IsServiceRunning, Converter={StaticResource BoolToColorConverter}, ConverterParameter='StopBg|DisabledBg'}"
                                        TextColor="{Binding IsServiceRunning, Converter={StaticResource BoolToColorConverter}, ConverterParameter='White|DisabledText'}"
                                        FontAttributes="Bold"
                                        CornerRadius="8"
                                        HeightRequest="48"
                                        IsEnabled="{Binding IsServiceRunning}" />
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Tarjeta 2: Conexiones WebSocket -->
                    <Border StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="{AppThemeBinding Light={StaticResource CardStrokeLight}, Dark={StaticResource CardStrokeDark}}" BackgroundColor="{AppThemeBinding Light={StaticResource CardBgLight}, Dark={StaticResource CardBgDark}}" Padding="25">
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,4" Radius="8" Opacity="0.03" />
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="25">
                            <Label Text="Conexiones WebSocket" FontSize="16" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />

                            <!-- Info Box 1 -->
                            <Border StrokeShape="RoundRectangle 8" StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource InfoBoxBgLight}, Dark={StaticResource InfoBoxBgDark}}" Padding="20,15">
                                <Grid ColumnDefinitions="*, Auto">
                                    <Label Grid.Column="0" Text="Clientes conectados" FontSize="14" TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" VerticalOptions="Center" />
                                    <Label Grid.Column="1" Text="{Binding CurrentClientCount}" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource TextPurple}" VerticalOptions="Center" />
                                </Grid>
                            </Border>

                            <!-- Info Box 2 -->
                            <Border StrokeShape="RoundRectangle 8" StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource InfoBoxBgLight}, Dark={StaticResource InfoBoxBgDark}}" Padding="20,15">
                                <Grid ColumnDefinitions="*, Auto">
                                    <Label Grid.Column="0" Text="Estado del socket" FontSize="14" TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" VerticalOptions="Center" />
                                    <HorizontalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                                        <Ellipse Fill="{Binding IsWebSocketServerRunning, Converter={StaticResource BoolToColorConverter}, ConverterParameter='Running|Stopped'}" WidthRequest="6" HeightRequest="6" VerticalOptions="Center" />
                                        <Label Text="{Binding IsWebSocketServerRunning, Converter={StaticResource BoolToStringConverter}, ConverterParameter='Activo|Inactivo'}" FontSize="14" FontAttributes="Bold" TextColor="{Binding IsWebSocketServerRunning, Converter={StaticResource BoolToColorConverter}, ConverterParameter='RunningText|StoppedText'}" VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                </Grid>
                            </Border>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>