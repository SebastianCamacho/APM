<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:UI.ViewModels"
             xmlns:converters="clr-namespace:UI.Converters"
             x:Class="UI.Views.PrinterDetailPage"
             Title="Configuración de Impresora"
             x:DataType="viewmodels:PrinterDetailViewModel"
             BackgroundColor="{AppThemeBinding Light={StaticResource PageBgLight}, Dark={StaticResource PageBgDark}}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
            <converters:NumericToStringConverter x:Key="NumericToStringConverter" />
            
            <!-- Estilo Premium para Entradas -->
            <Style TargetType="Entry">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />
                <Setter Property="BackgroundColor" Value="Transparent" />
                <Setter Property="PlaceholderColor" Value="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" />
            </Style>

            <!-- Estilo Premium para Pickers -->
            <Style TargetType="Picker">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />
                <Setter Property="TitleColor" Value="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" />
                <Setter Property="BackgroundColor" Value="Transparent" />
            </Style>

            <!-- Estilo de Contenedores de Input (Los bordes grises) -->
            <Style x:Key="InputContainerStyle" TargetType="Border">
                <Setter Property="StrokeShape" Value="RoundRectangle 8" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource CardStrokeLight}, Dark={StaticResource CardStrokeDark}}" />
                <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource NeutralTintBgLight}, Dark={StaticResource NeutralTintBgDark}}" />
                <Setter Property="HeightRequest" Value="{OnPlatform Android=40, Default=35}" />
            </Style>

            <!-- Estilo para Labels Titulares de Campo -->
            <Style x:Key="FieldLabelStyle" TargetType="Label">
                <Setter Property="FontSize" Value="13" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" />
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="{OnPlatform Android='10,15', Default='30,10'}" Spacing="{OnPlatform Android=15, Default=10}" HorizontalOptions="{OnPlatform Android=Fill, Default=Fill}" MaximumWidthRequest="1000" WidthRequest="{OnPlatform WinUI=800}">
                
                <!-- Encabezado de la Página -->
                <HorizontalStackLayout Spacing="10" VerticalOptions="Center" Margin="{OnPlatform Android='5,0,0,5', Default='0,0,0,5'}">
                    <Label Text="Configuración de Impresora" FontSize="22" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />
                </HorizontalStackLayout>

                <!-- Tarjeta Principal Blanca -->
                <Border StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="{AppThemeBinding Light={StaticResource CardStrokeLight}, Dark={StaticResource CardStrokeDark}}" BackgroundColor="{AppThemeBinding Light={StaticResource CardBgLight}, Dark={StaticResource CardBgDark}}" Padding="{OnPlatform Android='15', Default='25,15'}">
                    <VerticalStackLayout Spacing="{OnPlatform Android=20, Default=12}">

                        <!-- FILA 1: ID de Impresora (Ancho completo) -->
                        <VerticalStackLayout Spacing="4">
                            <Label Text="ID de Impresora" Style="{StaticResource FieldLabelStyle}" />
                            <Border Style="{StaticResource InputContainerStyle}">
                                <Entry Text="{Binding Printer.PrinterId}" Placeholder="Ej: ImpresoraCocina" VerticalOptions="Center" Margin="10,0"/>
                            </Border>
                        </VerticalStackLayout>

                        <!-- FILA 2: Tipo de Impresora y Tipo de Conexión (Dinámico) -->
                        <Grid ColumnDefinitions="{OnPlatform Android='*', Default='*,*'}" RowDefinitions="{OnPlatform Android='Auto,Auto', Default='Auto'}" ColumnSpacing="20" RowSpacing="{OnPlatform Android=20, Default=15}">
                            
                            <!-- Tipo de Impresora -->
                            <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="4">
                                <Label Text="Tipo de Impresora" Style="{StaticResource FieldLabelStyle}" />
                                <Border Style="{StaticResource InputContainerStyle}">
                                    <Picker SelectedItem="{Binding SelectedPrinterType}" ItemsSource="{Binding PrinterTypes}" HorizontalOptions="Fill" VerticalOptions="Center" Margin="5,0"/>
                                </Border>
                            </VerticalStackLayout>

                            <!-- Tipo de Conexión -->
                            <VerticalStackLayout Grid.Row="{OnPlatform Android=1, Default=0}" Grid.Column="{OnPlatform Android=0, Default=1}" Spacing="4">
                                <Label Text="Tipo de Conexión" Style="{StaticResource FieldLabelStyle}" />
                                <Border Style="{StaticResource InputContainerStyle}">
                                    <Picker SelectedItem="{Binding SelectedConnectionType}" ItemsSource="{Binding ConnectionTypes}" HorizontalOptions="Fill" VerticalOptions="Center" Margin="5,0"/>
                                </Border>
                            </VerticalStackLayout>
                            
                        </Grid>

                        <!-- FILA 3: Dirección IP y Puerto -->
                        <!-- Usamos el mismo diseño en malla para alineación inteligente -->
                        <Grid ColumnDefinitions="{OnPlatform Android='*', Default='*,*'}" RowDefinitions="{OnPlatform Android='Auto,Auto', Default='Auto'}" ColumnSpacing="20" RowSpacing="{OnPlatform Android=20, Default=15}" IsVisible="{Binding IsTcpConnection}">
                            
                            <!-- Dirección IP (Segmentada) -->
                            <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="4">
                                <Label Text="Dirección IP" Style="{StaticResource FieldLabelStyle}" />
                                <Grid ColumnDefinitions="*,Auto,*,Auto,*,Auto,*" ColumnSpacing="4">
                                    <Border Grid.Column="0" Style="{StaticResource InputContainerStyle}">
                                        <Entry Text="{Binding IpSegment1}" Keyboard="Numeric" MaxLength="3" HorizontalTextAlignment="Center" VerticalOptions="Center" />
                                    </Border>
                                    <Label Grid.Column="1" Text="." VerticalOptions="Center" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" />
                                    
                                    <Border Grid.Column="2" Style="{StaticResource InputContainerStyle}">
                                        <Entry Text="{Binding IpSegment2}" Keyboard="Numeric" MaxLength="3" HorizontalTextAlignment="Center" VerticalOptions="Center" />
                                    </Border>
                                    <Label Grid.Column="3" Text="." VerticalOptions="Center" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" />
                                    
                                    <Border Grid.Column="4" Style="{StaticResource InputContainerStyle}">
                                        <Entry Text="{Binding IpSegment3}" Keyboard="Numeric" MaxLength="3" HorizontalTextAlignment="Center" VerticalOptions="Center" />
                                    </Border>
                                    <Label Grid.Column="5" Text="." VerticalOptions="Center" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" />
                                    
                                    <Border Grid.Column="6" Style="{StaticResource InputContainerStyle}">
                                        <Entry Text="{Binding IpSegment4}" Keyboard="Numeric" MaxLength="3" HorizontalTextAlignment="Center" VerticalOptions="Center" />
                                    </Border>
                                </Grid>
                            </VerticalStackLayout>

                            <!-- Puerto -->
                            <VerticalStackLayout Grid.Row="{OnPlatform Android=1, Default=0}" Grid.Column="{OnPlatform Android=0, Default=1}" Spacing="4">
                                <Label Text="Puerto" Style="{StaticResource FieldLabelStyle}" />
                                <Border Style="{StaticResource InputContainerStyle}">
                                    <Entry Text="{Binding Printer.Port, Converter={StaticResource NumericToStringConverter}}" Keyboard="Numeric" VerticalOptions="Center" Margin="10,0"/>
                                </Border>
                            </VerticalStackLayout>

                        </Grid>

                        <!-- Nombre Impresora Local (Solo USB) -->
                        <VerticalStackLayout Spacing="4" IsVisible="{Binding IsUsbConnection}">
                            <Label Text="Nombre Impresora Local (Windows)" Style="{StaticResource FieldLabelStyle}" />
                            <Border Style="{StaticResource InputContainerStyle}">
                                <Entry Text="{Binding Printer.LocalPrinterName}" Placeholder="Ej: EPSON LX-300+ II" VerticalOptions="Center" Margin="10,0"/>
                            </Border>
                        </VerticalStackLayout>

                        <!-- URI IPP (Solo IPP) -->
                        <VerticalStackLayout Spacing="4" IsVisible="{Binding IsIppConnection}">
                            <Label Text="URI de Impresión (IPP/HTTP)" Style="{StaticResource FieldLabelStyle}" />
                            <Border Style="{StaticResource InputContainerStyle}">
                                <Entry Text="{Binding ManualUri}" Placeholder="Ej: ipp://192.168.1.50/ipp/print" VerticalOptions="Center" Margin="10,0"/>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Ancho Papel -->
                        <VerticalStackLayout Spacing="4" IsVisible="{Binding ShowThermalFields}">
                            <Label Text="Ancho Papel (mm)" Style="{StaticResource FieldLabelStyle}" />
                            <Border Style="{StaticResource InputContainerStyle}">
                                <Picker SelectedItem="{Binding SelectedPaperWidthMm}" ItemsSource="{Binding AvailablePaperWidths}" HorizontalOptions="Fill" VerticalOptions="Center" Margin="5,0"/>
                            </Border>
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource CardStrokeLight}, Dark={StaticResource CardStrokeDark}}" Margin="0,5" IsVisible="{Binding ShowThermalFields}" />

                        <!-- Switches Premium -->
                        <VerticalStackLayout Spacing="10" Margin="0" IsVisible="{Binding ShowThermalFields}">
                            <Grid ColumnDefinitions="*, Auto">
                                <Label Grid.Column="0" Text="Beep al imprimir" VerticalOptions="Center" FontSize="14" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />
                                <Switch Grid.Column="1" IsToggled="{Binding Printer.BeepOnPrint}" OnColor="{DynamicResource Primary}" />
                            </Grid>
                            
                            <Grid ColumnDefinitions="*, Auto">
                                <Label Grid.Column="0" Text="Abrir cajón al final" VerticalOptions="Center" FontSize="14" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />
                                <Switch Grid.Column="1" IsToggled="{Binding Printer.OpenCashDrawerAfterPrint}" OnColor="{DynamicResource Primary}" />
                            </Grid>
                            
                            <Grid ColumnDefinitions="*, Auto">
                                <Label Grid.Column="0" Text="Abrir cajón sin imprimir" VerticalOptions="Center" FontSize="14" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />
                                <Switch Grid.Column="1" IsToggled="{Binding Printer.OpenCashDrawerWithoutPrint}" OnColor="{DynamicResource Primary}" />
                            </Grid>
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource CardStrokeLight}, Dark={StaticResource CardStrokeDark}}" Margin="0,5,0,5" />

                        <!-- Botón Footer flotando a la derecha -->
                        <HorizontalStackLayout HorizontalOptions="End" Spacing="15">
                            <Button Text="Cancelar" 
                                    Command="{Binding CancelCommand}" 
                                    BackgroundColor="Transparent" 
                                    TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}"
                                    FontAttributes="Bold"
                                    HeightRequest="40" />

                            <Button Text="Guardar Impresora" 
                                    Command="{Binding SavePrinterCommand}"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                                    BackgroundColor="{DynamicResource Primary}"
                                    TextColor="White"
                                    FontAttributes="Bold"
                                    CornerRadius="8"
                                    Padding="25,0"
                                    HeightRequest="40" />
                        </HorizontalStackLayout>

                    </VerticalStackLayout>
                </Border>
                
            </VerticalStackLayout>
        </ScrollView>

        <!-- Indicador de Carga -->
        <Border Grid.RowSpan="3" IsVisible="{Binding IsBusy}" BackgroundColor="{AppThemeBinding Light=#80FFFFFF, Dark=#80000000}" StrokeThickness="0">
            <ActivityIndicator IsRunning="{Binding IsBusy}" VerticalOptions="Center" HorizontalOptions="Center" Color="{DynamicResource Primary}" WidthRequest="50" HeightRequest="50" />
        </Border>
    </Grid>
</ContentPage>
