<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:UI.ViewModels"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="UI.Views.ScalesPage"
             Title="Básculas"
             BackgroundColor="{AppThemeBinding Light={StaticResource PageBgLight}, Dark={StaticResource PageBgDark}}"
             x:DataType="viewmodels:ScalesViewModel">

    <ContentPage.Resources>
        <!-- Efecto Hover Dinámico para Ocultar/Mostrar Iconos en Windows -->
        <Style x:Key="ActionIconStyle" TargetType="ImageButton">
            <!-- Por defecto en Android siempre es visible, en Windows los ocultamos para el Hover -->
            <Setter Property="IsVisible" Value="{OnPlatform Android=True, Default=False}" />
            <Setter Property="Opacity" Value="0.6" />
            <Setter Property="BackgroundColor" Value="Transparent" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="VisualStateManager.VisualStateGroups">
                <VisualStateGroupList>
                    <VisualStateGroup x:Name="CommonStates">
                        <VisualState x:Name="Normal" />
                        <VisualState x:Name="PointerOver">
                            <VisualState.Setters>
                                <Setter Property="Opacity" Value="1.0" />
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateGroupList>
            </Setter>
        </Style>
    </ContentPage.Resources>

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Añadir Báscula" Command="{Binding AddScaleCommand}" IconImageSource="icono_anadir_impresora.svg" />
    </ContentPage.ToolbarItems>

    <ContentPage.Content>
        <Grid RowDefinitions="Auto, *" RowSpacing="20" Padding="{OnPlatform Android='15,20', Default='40,30'}">
            
            <!-- Encabezado y Acción Principal -->
            <Grid Grid.Row="0" ColumnDefinitions="*, Auto">
                <VerticalStackLayout Grid.Column="0" Spacing="5" VerticalOptions="Center">
                    <Label Text="Gestión de Básculas" FontSize="28" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />
                    <Label Text="Administra y configura las balanzas pesadoras del sistema" FontSize="14" TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" />
                </VerticalStackLayout>
                
                <Button Grid.Column="1" Text="Nueva Báscula" ImageSource="icono_anadir_impresora.svg"
                        Command="{Binding AddScaleCommand}"
                        BackgroundColor="{DynamicResource Primary}" TextColor="White"
                        CornerRadius="8" Padding="15,0" HeightRequest="40" FontAttributes="Bold" />
            </Grid>

            <!-- Grid de Tarjetas de Básculas -->
            <CollectionView Grid.Row="1" ItemsSource="{Binding Scales}" SelectionMode="None">
                <CollectionView.ItemsLayout>
                    <!-- Columnas adaptativas: 1 en móviles, 2 en Desktop -->
                    <GridItemsLayout Orientation="Vertical" Span="{OnPlatform Android=1, Default=2}" VerticalItemSpacing="15" HorizontalItemSpacing="15" />
                </CollectionView.ItemsLayout>

                <CollectionView.EmptyView>
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="15">
                        <Label Text="No hay básculas configuradas." FontSize="18" TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" />
                        <Button Text="Añadir Primera Báscula" Command="{Binding AddScaleCommand}" BackgroundColor="{DynamicResource Primary}" TextColor="White" CornerRadius="8" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="viewmodels:ScaleViewModelItem">
                        
                        <!-- Tarjeta Principal con VisualStateManager -->
                        <Border StrokeShape="RoundRectangle 12" StrokeThickness="1"
                                Stroke="{AppThemeBinding Light={StaticResource CardStrokeLight}, Dark={StaticResource CardStrokeDark}}"
                                BackgroundColor="{AppThemeBinding Light={StaticResource CardBgLight}, Dark={StaticResource CardBgDark}}"
                                Padding="20">
                            
                            <!-- Hover Transitions en XAML (Borde y Fondo) -->
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup Name="CommonStates">
                                    <VisualState Name="Normal" />
                                    <VisualState Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" />
                                            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource NeutralTintBgLight}, Dark={StaticResource NeutralTintBgDark}}" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>

                            <!-- Gestos Puntero (C#) y Clic -->
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:ScalesViewModel}}, Path=EditScaleCommand}" CommandParameter="{Binding .}" />
                                <PointerGestureRecognizer PointerEntered="OnCardPointerEntered" PointerExited="OnCardPointerExited" />
                            </Border.GestureRecognizers>

                            <!-- Grid Interno de la Tarjeta (Icono + Info) -->
                            <Grid ColumnDefinitions="Auto, *, Auto">
                                
                                <!-- Sección Izquierda: Icono Principal con Badge de Estado Flotante -->
                                <Grid Grid.Column="0" Margin="0,0,15,0" VerticalOptions="Center">
                                    <Border StrokeShape="RoundRectangle 8" StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryTintBgLight}, Dark={StaticResource PrimaryTintBgDark}}" Padding="12">
                                        <Image Source="icono_balanza.png" HeightRequest="40" WidthRequest="40" VerticalOptions="Center" HorizontalOptions="Center">
                                            <Image.Behaviors>
                                                <toolkit:IconTintColorBehavior TintColor="{DynamicResource Primary}" />
                                            </Image.Behaviors>
                                        </Image>
                                    </Border>
                                    
                                    <!-- Punto de Estado Flotante -->
                                    <Border StrokeShape="RoundRectangle 8" StrokeThickness="2" Stroke="{AppThemeBinding Light={StaticResource CardBgLight}, Dark={StaticResource CardBgDark}}" BackgroundColor="{Binding StatusColor}" 
                                            HeightRequest="16" WidthRequest="16" HorizontalOptions="End" VerticalOptions="End" TranslationX="5" TranslationY="5" />
                                </Grid>

                                <!-- Sección Central: Información de la Báscula -->
                                <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center" Margin="0,0,0,10"> <!-- Margen inferior para no solapar iconos -->
                                    
                                    <!-- Nombre y Tags -->
                                    <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                                        <Label Text="{Binding Scale.Name}" FontAttributes="Bold" FontSize="18" TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" VerticalOptions="Center" />
                                        
                                        <!-- Puerto Tag -->
                                        <Border StrokeShape="RoundRectangle 6" BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryTintBgLight}, Dark={StaticResource PrimaryTintBgDark}}" StrokeThickness="0" Padding="8,4" VerticalOptions="Center">
                                            <Label Text="{Binding Scale.PortName}" FontSize="11" TextColor="{DynamicResource Primary}" FontAttributes="Bold" />
                                        </Border>
                                    </HorizontalStackLayout>
                                    
                                    <!-- ID -->
                                    <Label Text="{Binding Scale.Id}" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" LineBreakMode="CharacterWrap" />
                                    
                                    <!-- Especificaciones Técnicas Básicas -->
                                    <HorizontalStackLayout Spacing="4" Margin="0,2,0,0">
                                        <Label Text="{Binding Scale.BaudRate}" TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" FontSize="12" />
                                        <Label Text="bps •" TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" FontSize="12" />
                                        <Label Text="{Binding Scale.DataBits}" TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" FontSize="12" />
                                        <Label Text="bits" TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" FontSize="12" />
                                    </HorizontalStackLayout>
                                    
                                    <!-- Status / Estado de Conexión Lógico -->
                                    <Label Text="{Binding Status}" TextColor="{Binding StatusColor}" FontSize="12" FontAttributes="Bold" Margin="0,2,0,0" />

                                    <!-- Mensajes de Error (Si aplican) -->
                                    <Label Text="{Binding ErrorMessage}" IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}" TextColor="Red" FontSize="11" FontAttributes="Italic" LineBreakMode="WordWrap" Margin="0,4,0,0" />
                                </VerticalStackLayout>

                                <!-- Sección Derecha: Iconos de Acción Híbridos -->
                                <HorizontalStackLayout Grid.Column="2" x:Name="ActionIcons" Spacing="6" 
                                                       VerticalOptions="{OnPlatform Android=End, Default=Center}" 
                                                       HorizontalOptions="End"
                                                       IsVisible="{OnPlatform Android=True, Default=False}" 
                                                       Opacity="{OnPlatform Android=1, Default=0}">
                                    
                                    <!-- Editar -->
                                    <ImageButton x:Name="EditBtn" BackgroundColor="Transparent" CornerRadius="8" WidthRequest="36" HeightRequest="36" Padding="8"
                                                 Source="{OnPlatform Android='icono_edit.png', Default='icono_edit_gray.png'}"
                                                 Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:ScalesViewModel}}, Path=EditScaleCommand}"
                                                 CommandParameter="{Binding .}">
                                        <ImageButton.GestureRecognizers>
                                            <PointerGestureRecognizer PointerEntered="OnEditPointerEntered" PointerExited="OnEditPointerExited" />
                                        </ImageButton.GestureRecognizers>
                                    </ImageButton>

                                    <!-- Eliminar -->
                                    <ImageButton x:Name="DeleteBtn" BackgroundColor="Transparent" CornerRadius="8" WidthRequest="36" HeightRequest="36" Padding="8"
                                                 Source="{OnPlatform Android='icono_delete.png', Default='icono_delete_gray.png'}"
                                                 Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:ScalesViewModel}}, Path=DeleteScaleCommand}"
                                                 CommandParameter="{Binding .}">
                                        <ImageButton.GestureRecognizers>
                                            <PointerGestureRecognizer PointerEntered="OnDeletePointerEntered" PointerExited="OnDeletePointerExited" />
                                        </ImageButton.GestureRecognizers>
                                    </ImageButton>

                                </HorizontalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Overlay de Carga -->
            <ActivityIndicator Grid.RowSpan="2" IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                               VerticalOptions="Center" HorizontalOptions="Center" Color="{DynamicResource Primary}" />
        </Grid>
    </ContentPage.Content>
</ContentPage>
