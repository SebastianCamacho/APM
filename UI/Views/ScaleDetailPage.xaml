<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:UI.ViewModels"
             xmlns:converters="clr-namespace:UI.Converters"
             x:Class="UI.Views.ScaleDetailPage"
             Title="Configuración de Báscula"
             x:DataType="viewmodels:ScaleDetailViewModel"
             BackgroundColor="{AppThemeBinding Light={StaticResource PageBgLight}, Dark={StaticResource PageBgDark}}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
            
            <!-- Estilo Premium para Entradas -->
            <Style TargetType="Entry">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />
                <Setter Property="BackgroundColor" Value="Transparent" />
                <Setter Property="PlaceholderColor" Value="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" />
            </Style>

            <!-- Estilo Premium para Pickers -->
            <Style TargetType="Picker">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />
                <Setter Property="TitleColor" Value="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" />
                <Setter Property="BackgroundColor" Value="Transparent" />
            </Style>

            <!-- Estilo de Contenedores de Input (Los bordes grises) -->
            <Style x:Key="InputContainerStyle" TargetType="Border">
                <Setter Property="StrokeShape" Value="RoundRectangle 8" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource CardStrokeLight}, Dark={StaticResource CardStrokeDark}}" />
                <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource NeutralTintBgLight}, Dark={StaticResource NeutralTintBgDark}}" />
                <Setter Property="HeightRequest" Value="{OnPlatform Android=40, Default=35}" />
            </Style>

            <!-- Estilo para Labels Titulares de Campo -->
            <Style x:Key="FieldLabelStyle" TargetType="Label">
                <Setter Property="FontSize" Value="13" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" />
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="{OnPlatform Android='10,15', Default='30,10'}" Spacing="{OnPlatform Android=15, Default=10}" HorizontalOptions="{OnPlatform Android=Fill, Default=Fill}" MaximumWidthRequest="1000" WidthRequest="{OnPlatform Windows=800}">
                
                <!-- Encabezado de la Página -->
                <HorizontalStackLayout Spacing="10" VerticalOptions="Center" Margin="{OnPlatform Android='5,0,0,5', Default='0,0,0,5'}">
                    <Label Text="Configuración de Báscula" FontSize="22" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />
                </HorizontalStackLayout>

                <!-- Tarjeta Principal Blanca -->
                <Border StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="{AppThemeBinding Light={StaticResource CardStrokeLight}, Dark={StaticResource CardStrokeDark}}" BackgroundColor="{AppThemeBinding Light={StaticResource CardBgLight}, Dark={StaticResource CardBgDark}}" Padding="{OnPlatform Android='15', Default='25,15'}">
                    <VerticalStackLayout Spacing="{OnPlatform Android=20, Default=12}">

                        <!-- FILA 1: ID y Nombre (Misma fila en Windows, cascada en Android) -->
                        <Grid ColumnDefinitions="{OnPlatform Android='*', Default='*,*'}" RowDefinitions="{OnPlatform Android='Auto,Auto', Default='Auto'}" ColumnSpacing="20" RowSpacing="{OnPlatform Android=20, Default=15}">
                            
                            <!-- ID -->
                            <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="4">
                                <Label Text="ID de Báscula" Style="{StaticResource FieldLabelStyle}" />
                                <Border Style="{StaticResource InputContainerStyle}">
                                    <Entry Text="{Binding Id}" IsEnabled="{Binding IsNew}" Placeholder="Ej: bascula01" VerticalOptions="Center" Margin="10,0"/>
                                </Border>
                            </VerticalStackLayout>

                            <!-- Nombre -->
                            <VerticalStackLayout Grid.Row="{OnPlatform Android=1, Default=0}" Grid.Column="{OnPlatform Android=0, Default=1}" Spacing="4">
                                <Label Text="Nombre" Style="{StaticResource FieldLabelStyle}" />
                                <Border Style="{StaticResource InputContainerStyle}">
                                    <Entry Text="{Binding Name}" Placeholder="Ej: Báscula Principal" VerticalOptions="Center" Margin="10,0"/>
                                </Border>
                            </VerticalStackLayout>
                        </Grid>

                        <!-- FILA 2: Puerto COM -->
                        <VerticalStackLayout Spacing="4">
                            <!-- Label Simple Arriba -->
                            <Label Text="Puerto COM" Style="{StaticResource FieldLabelStyle}" />
                            
                            <!-- Borde con Picker y Botón a la derecha en paralelo -->
                            <Grid ColumnDefinitions="*, Auto" ColumnSpacing="10" VerticalOptions="Center">
                                
                                <Border Grid.Column="0" Style="{StaticResource InputContainerStyle}">
                                    <Picker ItemsSource="{Binding AvailablePorts}" SelectedItem="{Binding PortName}" 
                                            HorizontalOptions="Fill" VerticalOptions="Center" Margin="10,0" />
                                </Border>
                                
                                <Button x:Name="RefreshPortsBtn" Grid.Column="1" Text="⟳"
                                        FontSize="18" Padding="5,0" HeightRequest="40" WidthRequest="40"
                                        BackgroundColor="Transparent" TextColor="{DynamicResource Primary}"
                                        ToolTipProperties.Text="Actualizar Puertos" VerticalOptions="Center"
                                        Clicked="OnRefreshPortsClicked" />
                            </Grid>
                        </VerticalStackLayout>

                        <!-- Separador -->
                        <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource CardStrokeLight}, Dark={StaticResource CardStrokeDark}}" Margin="0,5" />
                        <Label Text="Configuración Serial" FontSize="16" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" Margin="0,0,0,5" />

                        <!-- FILA 3: Baud Rate y Data Bits -->
                        <Grid ColumnDefinitions="{OnPlatform Android='*', Default='*,*'}" RowDefinitions="{OnPlatform Android='Auto,Auto', Default='Auto'}" ColumnSpacing="20" RowSpacing="{OnPlatform Android=20, Default=15}">
                            
                            <!-- Baud Rate -->
                            <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="4">
                                <Label Text="Baud Rate" Style="{StaticResource FieldLabelStyle}" />
                                <Border Style="{StaticResource InputContainerStyle}">
                                    <Entry Text="{Binding BaudRate}" Keyboard="Numeric" VerticalOptions="Center" Margin="10,0"/>
                                </Border>
                            </VerticalStackLayout>

                            <!-- Data Bits -->
                            <VerticalStackLayout Grid.Row="{OnPlatform Android=1, Default=0}" Grid.Column="{OnPlatform Android=0, Default=1}" Spacing="4">
                                <Label Text="Data Bits" Style="{StaticResource FieldLabelStyle}" />
                                <Border Style="{StaticResource InputContainerStyle}">
                                    <Entry Text="{Binding DataBits}" Keyboard="Numeric" VerticalOptions="Center" Margin="10,0"/>
                                </Border>
                            </VerticalStackLayout>
                        </Grid>

                        <!-- FILA 4: Parity y Stop Bits -->
                        <Grid ColumnDefinitions="{OnPlatform Android='*', Default='*,*'}" RowDefinitions="{OnPlatform Android='Auto,Auto', Default='Auto'}" ColumnSpacing="20" RowSpacing="{OnPlatform Android=20, Default=15}">
                            
                            <!-- Parity -->
                            <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="4">
                                <Label Text="Parity" Style="{StaticResource FieldLabelStyle}" />
                                <Border Style="{StaticResource InputContainerStyle}">
                                    <Picker ItemsSource="{Binding ParityOptions}" SelectedItem="{Binding Parity}" HorizontalOptions="Fill" VerticalOptions="Center" Margin="10,0"/>
                                </Border>
                            </VerticalStackLayout>

                            <!-- Stop Bits -->
                            <VerticalStackLayout Grid.Row="{OnPlatform Android=1, Default=0}" Grid.Column="{OnPlatform Android=0, Default=1}" Spacing="4">
                                <Label Text="Stop Bits" Style="{StaticResource FieldLabelStyle}" />
                                <Border Style="{StaticResource InputContainerStyle}">
                                    <Picker ItemsSource="{Binding StopBitsOptions}" SelectedItem="{Binding StopBits}" HorizontalOptions="Fill" VerticalOptions="Center" Margin="10,0"/>
                                </Border>
                            </VerticalStackLayout>
                        </Grid>


                        <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource CardStrokeLight}, Dark={StaticResource CardStrokeDark}}" Margin="0,15,0,5" />

                        <!-- Botón Footer flotando a la derecha -->
                        <HorizontalStackLayout HorizontalOptions="End" Spacing="15">
                            <Button Text="Cancelar" 
                                    Command="{Binding GoBackCommand}" 
                                    BackgroundColor="Transparent" 
                                    TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}"
                                    FontAttributes="Bold"
                                    HeightRequest="40" />

                            <Button Text="Guardar Báscula" 
                                    Command="{Binding SaveCommand}"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                                    BackgroundColor="{DynamicResource Primary}"
                                    TextColor="White"
                                    FontAttributes="Bold"
                                    CornerRadius="8"
                                    Padding="25,0"
                                    HeightRequest="40" />
                        </HorizontalStackLayout>

                    </VerticalStackLayout>
                </Border>
                
            </VerticalStackLayout>
        </ScrollView>

        <!-- Indicador de Carga sobrepuesto sobre toda la pantalla -->
        <Border Grid.RowSpan="3" IsVisible="{Binding IsBusy}" BackgroundColor="{AppThemeBinding Light=#80FFFFFF, Dark=#80000000}" StrokeThickness="0">
            <ActivityIndicator IsRunning="{Binding IsBusy}" VerticalOptions="Center" HorizontalOptions="Center" Color="{DynamicResource Primary}" WidthRequest="50" HeightRequest="50" />
        </Border>
    </Grid>
</ContentPage>
