<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:UI.ViewModels"
             xmlns:model="clr-namespace:AppsielPrintManager.Core.Models;assembly=Core"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="UI.Views.PrintersPage"
             Title="Impresoras"
             x:DataType="viewmodels:PrintersViewModel">

    <ContentPage.Resources>
        <ResourceDictionary>
            <!-- Efecto Hover Dinámico para Ocultar/Mostrar Iconos en Windows -->
            <Style x:Key="ActionIconStyle" TargetType="ImageButton">
                <!-- Por defecto en Android siempre es visible, en Windows los ocultamos para el Hover -->
                <Setter Property="IsVisible" Value="{OnPlatform Android=True, Default=False}" />
                <Setter Property="Opacity" Value="0.6" />
                <Setter Property="BackgroundColor" Value="Transparent" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="VisualStateManager.VisualStateGroups">
                    <VisualStateGroupList>
                        <VisualStateGroup x:Name="CommonStates">
                            <VisualState x:Name="Normal" />
                            <VisualState x:Name="PointerOver">
                                <VisualState.Setters>
                                    <Setter Property="Opacity" Value="1.0" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateGroupList>
                </Setter>
            </Style>

            <!-- Estilo Hover para la Tarjeta de la Impresora (Revela las acciones hijas) -->
            <Style x:Key="PrinterCardStyle" TargetType="Border">
                <Setter Property="StrokeShape" Value="RoundRectangle 12" />
                <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource CardStrokeLight}, Dark={StaticResource CardStrokeDark}}" />
                <Setter Property="StrokeThickness" Value="1.0" />
                <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource CardBgLight}, Dark={StaticResource CardBgDark}}" />
                <Setter Property="Padding" Value="20" />
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid BackgroundColor="{AppThemeBinding Light={StaticResource PageBgLight}, Dark={StaticResource PageBgDark}}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header Toolbar Falso -->
        <Border Grid.Row="0" StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource CardBgLight}, Dark={StaticResource CardBgDark}}" Padding="30,15" Margin="0,0,0,5">
            <Border.Shadow>
                <Shadow Brush="#000000" Offset="0,2" Radius="5" Opacity="0.05" />
            </Border.Shadow>
            <Grid ColumnDefinitions="*, Auto">
                <Label Grid.Column="0" Text="Impresoras" FontSize="14" TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" VerticalOptions="Center" />
                <!-- Status Indicator with Pulses (Omitido por ahora si no está en VM, usar hardcoded o bindings reales) -->
                <HorizontalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="Center">
                    <Ellipse Fill="#10B981" WidthRequest="10" HeightRequest="10" VerticalOptions="Center" />
                    <Label Text="Servicio Activo" FontSize="13" TextColor="{AppThemeBinding Light=#333A45, Dark=#E1E5EA}" FontAttributes="Bold" VerticalOptions="Center" />
                </HorizontalStackLayout>
            </Grid>
        </Border>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="30,20" Spacing="25">
                
                <!-- Título y Botón Añadir -->
                <Grid ColumnDefinitions="*, Auto">
                    <Label Grid.Column="0" Text="Impresoras" FontSize="26" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" VerticalOptions="Center" />
                    
                    <Button Grid.Column="1" 
                            Text="+ Añadir" 
                            Command="{Binding AddPrinterCommand}" 
                            BackgroundColor="{DynamicResource Primary}" 
                            TextColor="White" 
                            FontAttributes="Bold" 
                            CornerRadius="8" 
                            Padding="20,10"
                            HeightRequest="42" />
                </Grid>

                <!-- Vista Vacía -->
                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center"
                                     Padding="40" Spacing="15" IsVisible="{Binding HasNoPrinters}">
                    <Image Source="icono_impresora.png" HeightRequest="60" WidthRequest="60" HorizontalOptions="Center" Opacity="0.3" />
                    <Label Text="No hay impresoras configuradas aún." FontSize="16" TextColor="Gray" HorizontalOptions="Center" />
                </VerticalStackLayout>

                <!-- Lista Responsiva (Grid Windows, Block Android) -->
                <CollectionView ItemsSource="{Binding Printers}" SelectionMode="None"
                                IsVisible="{Binding HasNoPrinters, Converter={StaticResource InverseBoolConverter}}">
                    
                    <!-- Magia FlexLayout para Responsive Design -->
                    <CollectionView.ItemsLayout>
                        <!-- En Windows se comportará como un CSS Flex Wrap al indicarle ItemSpacing -->
                        <GridItemsLayout Orientation="Vertical" Span="{OnPlatform Android=1, Default=2}" HorizontalItemSpacing="20" VerticalItemSpacing="20" />
                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="model:PrinterSettings">
                            <Border Style="{StaticResource PrinterCardStyle}" VerticalOptions="Fill">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:PrintersViewModel}}, Path=EditPrinterCommand}"
                                                          CommandParameter="{Binding .}" />
                                    <PointerGestureRecognizer PointerEntered="OnCardPointerEntered" PointerExited="OnCardPointerExited" />
                                </Border.GestureRecognizers>
                                <Border.VisualStateManager>
                                    <VisualStateGroupList>
                                        <VisualStateGroup x:Name="CommonStates">
                                            <VisualState x:Name="Normal">
                                                <VisualState.Setters>
                                                    <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource CardStrokeLight}, Dark={StaticResource CardStrokeDark}}" />
                                                    <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource CardBgLight}, Dark={StaticResource CardBgDark}}" />
                                                </VisualState.Setters>
                                            </VisualState>
                                            <VisualState x:Name="PointerOver">
                                                <VisualState.Setters>
                                                    <Setter Property="Stroke" Value="{DynamicResource PrimaryLight}" />
                                                    <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource CardHoverBgLight}, Dark={StaticResource CardHoverBgDark}}" />
                                                </VisualState.Setters>
                                            </VisualState>
                                        </VisualStateGroup>
                                    </VisualStateGroupList>
                                </Border.VisualStateManager>
                                <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="15">
                                        
                                        <!-- Cajita Lila del Ícono -->
                                        <Border Grid.Column="0" StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryTintBgLight}, Dark={StaticResource PrimaryTintBgDark}}" StrokeShape="RoundRectangle 12" WidthRequest="55" HeightRequest="55" VerticalOptions="Start">
                                            <Image Source="icono_impresora.png" HeightRequest="28" WidthRequest="28" HorizontalOptions="Center" VerticalOptions="Center">
                                                <Image.Behaviors>
                                                    <toolkit:IconTintColorBehavior TintColor="{DynamicResource Primary}" />
                                                </Image.Behaviors>
                                            </Image>
                                        </Border>

                                        <!-- Información Central -->
                                        <VerticalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="Center">
                                            <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                                                <Label Text="{Binding PrinterId}" FontAttributes="Bold" FontSize="18" TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" VerticalOptions="Center" />
                                                
                                                <!-- Badges de Tipo y Conexión -->
                                                <Border StrokeShape="RoundRectangle 6" StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryTintBgLight}, Dark={StaticResource PrimaryTintBgDark}}" Padding="6,2" VerticalOptions="Center">
                                                    <Label Text="{Binding PrinterType, StringFormat='{0}'}" FontSize="10" TextColor="{DynamicResource Primary}" FontAttributes="Bold" />
                                                </Border>
                                                <Border StrokeShape="RoundRectangle 6" StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource NeutralTintBgLight}, Dark={StaticResource NeutralTintBgDark}}" Padding="6,2" VerticalOptions="Center">
                                                    <Label Text="{Binding ConnectionType}" FontSize="10" TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" FontAttributes="Bold" />
                                                </Border>
                                            </HorizontalStackLayout>
                                            
                                            <!-- IP y Detalles -->
                                            <HorizontalStackLayout Spacing="5">
                                                <Label Text="{Binding IpAddress}" TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" FontSize="13">
                                                    <Label.Triggers>
                                                        <DataTrigger TargetType="Label" Binding="{Binding ConnectionType}" Value="USB">
                                                            <Setter Property="IsVisible" Value="False" />
                                                        </DataTrigger>
                                                    </Label.Triggers>
                                                </Label>
                                                <Label Text="{Binding Port, StringFormat=':{0}'}" TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" FontSize="13">
                                                    <Label.Triggers>
                                                        <DataTrigger TargetType="Label" Binding="{Binding ConnectionType}" Value="USB">
                                                            <Setter Property="IsVisible" Value="False" />
                                                        </DataTrigger>
                                                        <DataTrigger TargetType="Label" Binding="{Binding ConnectionType}" Value="IPP">
                                                            <Setter Property="IsVisible" Value="False" />
                                                        </DataTrigger>
                                                    </Label.Triggers>
                                                </Label>
                                                <Label Text="{Binding LocalPrinterName}" TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" FontSize="13" IsVisible="False">
                                                    <Label.Triggers>
                                                        <DataTrigger TargetType="Label" Binding="{Binding ConnectionType}" Value="USB">
                                                            <Setter Property="IsVisible" Value="True" />
                                                        </DataTrigger>
                                                    </Label.Triggers>
                                                </Label>
                                                <Label Text="{Binding Uri}" TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" FontSize="13" IsVisible="False">
                                                    <Label.Triggers>
                                                        <DataTrigger TargetType="Label" Binding="{Binding ConnectionType}" Value="IPP">
                                                            <Setter Property="IsVisible" Value="True" />
                                                        </DataTrigger>
                                                    </Label.Triggers>
                                                </Label>
                                            </HorizontalStackLayout>

                                            <!-- Ancho de Papel -->
                                            <Label Text="{Binding PaperWidthMm, StringFormat='Ancho: {0}mm'}" TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" FontSize="13" Opacity="0">
                                                <Label.Triggers>
                                                    <DataTrigger TargetType="Label" Binding="{Binding PrinterType}" Value="Térmica">
                                                        <Setter Property="Opacity" Value="1" />
                                                    </DataTrigger>
                                                </Label.Triggers>
                                            </Label>
                                        </VerticalStackLayout>
                                        
                                        <!-- Iconos de Acción Flotantes (Controlados por VisualState) -->
                                        <HorizontalStackLayout x:Name="ActionIcons" Grid.Column="2" Spacing="8" VerticalOptions="Start" Opacity="{OnPlatform Android=1, Default=0}">
                                            <!-- Botón Editar -->
                                            <ImageButton Source="icono_edit.png" 
                                                         Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:PrintersViewModel}}, Path=EditPrinterCommand}"
                                                         CommandParameter="{Binding .}"
                                                         WidthRequest="32" HeightRequest="32" Padding="6" BackgroundColor="Transparent" CornerRadius="8">
                                                         <VisualStateManager.VisualStateGroups>
                                                    <VisualStateGroup x:Name="CommonStates">
                                                        <VisualState x:Name="Normal">
                                                            <VisualState.Setters>
                                                                <Setter Property="BackgroundColor" Value="Transparent" />
                                                            </VisualState.Setters>
                                                        </VisualState>
                                                        <VisualState x:Name="PointerOver">
                                                            <VisualState.Setters>
                                                                <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource PrimaryTintBgLight}, Dark={StaticResource PrimaryTintBgDark}}" />
                                                            </VisualState.Setters>
                                                        </VisualState>
                                                    </VisualStateGroup>
                                                </VisualStateManager.VisualStateGroups>
                                            </ImageButton>

                                            <!-- Botón Eliminar -->
                                            <ImageButton Source="icono_delete.png" 
                                                         Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:PrintersViewModel}}, Path=DeletePrinterCommand}"
                                                         CommandParameter="{Binding .}"
                                                         WidthRequest="32" HeightRequest="32" Padding="6" BackgroundColor="Transparent" CornerRadius="8">
                                                <VisualStateManager.VisualStateGroups>
                                                    <VisualStateGroup x:Name="CommonStates">
                                                        <VisualState x:Name="Normal">
                                                            <VisualState.Setters>
                                                                <Setter Property="BackgroundColor" Value="Transparent" />
                                                            </VisualState.Setters>
                                                        </VisualState>
                                                        <VisualState x:Name="PointerOver">
                                                            <VisualState.Setters>
                                                                <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource DangerTintBgLight}, Dark={StaticResource DangerTintBgDark}}" />
                                                            </VisualState.Setters>
                                                        </VisualState>
                                                    </VisualStateGroup>
                                                </VisualStateManager.VisualStateGroups>
                                            </ImageButton>
                                        </HorizontalStackLayout>
                                        
                                    </Grid>
                                </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>
        <ActivityIndicator Grid.Row="1" IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" VerticalOptions="Center" HorizontalOptions="Center" Color="{DynamicResource Primary}" />
    </Grid>
</ContentPage>
