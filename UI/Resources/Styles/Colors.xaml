<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Note: For Android please see also Platforms\Android\Resources\values\colors.xml -->

    <Color x:Key="Primary">#512BD4</Color>
    <Color x:Key="PrimaryDark">#ac99ea</Color>
    <Color x:Key="PrimaryDarkText">#242424</Color>
    <Color x:Key="Secondary">#DFD8F7</Color>
    <Color x:Key="SecondaryDarkText">#9880e5</Color>
    <Color x:Key="Tertiary">#2B0B98</Color>

    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="Magenta">#D600AA</Color>
    <Color x:Key="MidnightBlue">#190649</Color>
    <Color x:Key="OffBlack">#1f1f1f</Color>

    <Color x:Key="Gray100">#E1E1E1</Color>
    <Color x:Key="Gray200">#C8C8C8</Color>
    <Color x:Key="Gray300">#ACACAC</Color>
    <Color x:Key="Gray400">#919191</Color>
    <Color x:Key="Gray500">#6E6E6E</Color>
    <Color x:Key="Gray600">#404040</Color>
    <Color x:Key="Gray900">#212121</Color>
    <Color x:Key="Gray950">#141414</Color>

    <!-- Service Status Colors -->
    <Color x:Key="Running">#1EA565</Color>
    <Color x:Key="Stopped">#D23232</Color>
    
    <Color x:Key="RunningText">#116F42</Color>
    <Color x:Key="StoppedText">#9D1F1F</Color>
    
    <Color x:Key="RunningBg">#DCFCE7</Color>
    <Color x:Key="StoppedBg">#FEE2E2</Color>
    
    <Color x:Key="StartBg">#159154</Color>
    <Color x:Key="StopBg">#CD2121</Color>
    <Color x:Key="DisabledBg">#Eef0F2</Color>
    <Color x:Key="DisabledText">#9BA3AB</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>

    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}"/>

    <!-- ============================================== -->
    <!-- PREMUM UI REDESIGN COLORS (Global Abstraction) -->
    <!-- ============================================== -->

    <!-- Backgrounds & Surfaces -->
    <Color x:Key="PageBgLight">#F5F7FA</Color>
    <Color x:Key="PageBgDark">#1A1C1E</Color>
    <Color x:Key="CardBgLight">White</Color>
    <Color x:Key="CardBgDark">#2D3033</Color>
    <Color x:Key="InnerCardBgLight">#F5F7FA</Color>
    <Color x:Key="InnerCardBgDark">#33383D</Color>
    <Color x:Key="InfoBoxBgLight">#F8F9FA</Color>
    <Color x:Key="InfoBoxBgDark">#33383D</Color>

    <!-- Typography -->
    <Color x:Key="TextPrimaryLight">#1D263B</Color>
    <Color x:Key="TextPrimaryDark">White</Color>
    <Color x:Key="TextSecondaryLight">#5A6A85</Color>
    <Color x:Key="TextSecondaryDark">#A9B4C2</Color>
    <Color x:Key="TextMutedLight">#8E9EAA</Color>
    <Color x:Key="TextMutedDark">#8A949E</Color>
    <Color x:Key="TextPurple">#6B21A8</Color>

    <!-- Borders & Strokes -->
    <Color x:Key="CardStrokeLight">#EAECEE</Color>
    <Color x:Key="CardStrokeDark">#3A3F45</Color>

    <!-- Badges & Interactivity (Tints) -->
    <Color x:Key="PrimaryTintBgLight">#F4F0FF</Color>
    <Color x:Key="PrimaryTintBgDark">#2A2542</Color>
    <Color x:Key="NeutralTintBgLight">#F0F2F5</Color>
    <Color x:Key="NeutralTintBgDark">#3A3F45</Color>
    <Color x:Key="DangerTintBgLight">#FEF2F2</Color>
    <Color x:Key="DangerTintBgDark">#3F282A</Color>
    
    <!-- Hover Effects for Cards/Buttons -->
    <Color x:Key="CardHoverBgLight">#FCFBFF</Color>
    <Color x:Key="CardHoverBgDark">#33313B</Color>

</ResourceDictionary>